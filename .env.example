# ─────────────────────────────────────────────────────────────
# CarDuka AI Agent Demo — environment variables
# Copy to .env for local dev. On Railway, set these per-service.
# ─────────────────────────────────────────────────────────────

# ── api service (PRIVATE) ──
# At least one LLM provider key is REQUIRED at runtime (fail-fast otherwise).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx           # failover only (optional but recommended)

ANTHROPIC_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile

JWT_SECRET=change-me-to-a-long-random-string
BID_SIGNING_SECRET=change-me-to-another-long-random-string
REDIS_URL=redis://localhost:6379/0                 # unset -> in-memory fallback
# Local/test only. Production/Railway requires Redis and will not silently fall back.
ALLOW_IN_MEMORY_SESSIONS=true
APP_ENV=development

# ── web service (PUBLIC, Next.js BFF) ──
# Server-only, runtime-resolved. NOT prefixed with NEXT_PUBLIC_, not needed at build.
API_INTERNAL_URL=http://localhost:8000
